# ============================================================================
# Variables de entorno para tests de Bustoke.
#
# Este archivo documenta las variables que controlan la suite de testing.
# NO contiene secretos reales. Cópialo como `.env` si necesitas overrides
# locales, pero NO lo commitees.
# ============================================================================

# ----------------------------------------------------------------------------
# Cypress (E2E UI)
# ----------------------------------------------------------------------------
# URL del frontend React que Cypress debe atacar.
# Default si no se setea: http://localhost:5173 (Vite dev server)
# CYPRESS_BASE_URL=http://localhost:5173

# URL del backend FastAPI para las llamadas cy.request() (sin /v1 al final).
# Default si no se setea: http://localhost:8000/v1
# Para apuntar a staging (Render free tier, atención a cold starts):
# CYPRESS_API_URL=https://bustoke-backend.onrender.com/v1

# ----------------------------------------------------------------------------
# Backend (pytest)
# ----------------------------------------------------------------------------
# Las variables del backend se leen de `backend/.env`. La suite de pytest
# corre contra PostgreSQL real (BD `bustoke_test` local). Antes de la
# primera ejecución:
#   psql -U postgres -d bustoke_test -f backend/scripts/bustoke_bd.sql
# Por defecto apunta a postgres/postgres en localhost:5432/bustoke_test.
# Para apuntar a otra BD, exportar `TEST_DATABASE_URL` en el entorno
# antes de invocar pytest (ver backend/tests/api/conftest.py).
APP_ENV=test
APP_DEBUG=false
SECRET_KEY=test-secret-key-not-for-prod
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
SEAT_HOLD_TTL_SECONDS=600

# ----------------------------------------------------------------------------
# Seguridad (OWASP) — aplican a backend y CI
# ----------------------------------------------------------------------------
# RATE_LIMIT_ENABLED: en pytest se desactiva automáticamente
# (los tests comparten la key 'testclient' y se bloquearían).
# En staging/prod debe estar en 'true' (default).
# RATE_LIMIT_ENABLED=true

# CSP_ALLOW_INLINE_STYLES: permite 'unsafe-inline' en style-src.
# Solo necesario en dev (Vite inyecta estilos inline). En prod=false.
# CSP_ALLOW_INLINE_STYLES=false

# ----------------------------------------------------------------------------
# Comandos de ejecución
# ----------------------------------------------------------------------------
# Backend (carpeta backend/):
#   venv\Scripts\activate        # Windows
#   pytest tests/                # corre los 101 tests
#   pytest tests/api -v          # solo la suite consolidada
#   pytest tests/api/test_security_api.py -v  # solo los 17 tests de seguridad
#
# Frontend (carpeta frontend-client/):
#   npm install cypress --save-dev
#   npm run cy:open              # modo interactivo
#   npm run cy:run               # headless (CI)
#   npm run cy:run:chrome        # headless en Chrome explícito
#
# Staging (Render):
#   $env:CYPRESS_API_URL="https://bustoke-backend.onrender.com/v1"
#   npm run cy:run
#
# Generar un SECRET_KEY seguro (256+ bits de entropía):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
