# ==========================================================
# CONFIGURACIÓN DE ENTORNO - BUSTOKE BACKEND
# Copiar este archivo a .env y completar los valores reales.
# ==========================================================

# ---------- Aplicación ----------
APP_NAME=BUSTOKE API
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- Base de Datos PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bustoke_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO_SQL=False

# ---------- Seguridad / JWT ----------
# Generar con: openssl rand -hex 32
SECRET_KEY=cambia_esta_clave_secreta_por_una_aleatoria_segura
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_API_KEY_EXPIRE_DAYS=365

# ---------- CORS ----------
# Lista separada por comas. Usar "*" solo en desarrollo.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,https://bustoke-clientes.vercel.app

# ---------- Bloqueo temporal de asientos (segundos) ----------
SEAT_HOLD_TTL_SECONDS=600

# ---------- Job de limpieza de holds expirados (FIX TC-RB-003) ----------
# Cada cuántos segundos se barren los holds con expira_at <= NOW()
# para marcarlos como estado='expirado'. Default: 300s (5 min).
HOLD_CLEANUP_INTERVAL_SECONDS=300
# Poner en true para desactivar el job (útil en tests).
HOLD_CLEANUP_DISABLED=false

# ---------- Email transaccional (RF-08) ----------
# Único proveedor soportado: SMTP genérico (Gmail, Mailtrap, etc.)
# Si SMTP_HOST no está configurado, los emails se omiten silenciosamente.
#
# Setup Gmail (recomendado para dev sin dominio):
# 1. Activar 2FA en https://myaccount.google.com/security
# 2. Generar App Password en https://myaccount.google.com/apppasswords
#    - Aplicación: "Correo"
#    - Dispositivo: "Otro (BUSTOKE Backend)" → 16 caracteres
# 3. Completar las variables SMTP_* abajo
#
# Funciona con CUALQUIER destinatario, no necesita dominio propio.
# Limitado a ~500 emails/día (suficiente para MVP).
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
# Si está vacío, usa SMTP_USER como remitente.
SMTP_FROM_EMAIL=
