# ==========================================================
# CONFIGURACIÓN DE ENTORNO - BUSTOKE BACKEND
# Copiar este archivo a .env y completar los valores reales.
# ==========================================================

# ---------- Aplicación ----------
APP_NAME=BUSTOKE API
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- Base de Datos PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bustoke_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO_SQL=False

# ---------- Seguridad / JWT ----------
# Generar con: openssl rand -hex 32
SECRET_KEY=cambia_esta_clave_secreta_por_una_aleatoria_segura
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_API_KEY_EXPIRE_DAYS=365

# ---------- CORS ----------
# Lista separada por comas. Usar "*" solo en desarrollo.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ---------- Bloqueo temporal de asientos (segundos) ----------
SEAT_HOLD_TTL_SECONDS=600

# ---------- Email transaccional (Resend - RF-08) ----------
# Crear cuenta en https://resend.com (gratis, 3000 emails/mes).
# Copiar la API key desde el dashboard de Resend.
# Si está vacía, los emails se omiten pero el resto del flujo funciona.
RESEND_API_KEY=
# Remitente de los emails. Por defecto usa el dominio de testing de Resend.
# Para producción, verificar tu dominio y usar algo como:
#   RESEND_FROM_EMAIL=BUSTOKE <no-reply@tu-dominio.com>
RESEND_FROM_EMAIL=BUSTOKE <onboarding@resend.dev>
